# Import dependencies
library(foreach)
library(doParallel)
# Detect number of cores and reserve all except for 1
detectCores() # I have 12 cores in my laptop
numCores <- detectCores() - 1 # Use 11 cores, in my case
registerDoParallel(numCores)
# Reinitialize  B0hat and B1hat
B0hat = rep(0, 10000)
B1hat = rep(0, 10000)
# Create the simulation study function
sim.function =  function(t){
x = rnorm(50, mean = 0, sd = 1)
se = rnorm(50, mean = 0, sd = 4)
y = 2 + 3*x +se
cdata = data.frame(cbind(y, x))
linModel = lm(y~x, cdata)
B0hat[t] = linModel$coefficients[1]
B1hat[t] = linModel$coefficients[2]
};
foreach(i = 1:10000) %dopar% sim.function(i)
B0hat
# Birthday Problem
# Function take input of n
birthday_sim <- function(n){
dup_count <- 0
ntests <- 10000
for(i in 1:ntests){
# Generate n birthdays
# Do that ntests times (in this case, 10,000)
dates <- sample(1:365, n, replace = TRUE)
# Check if all the birthdays are unique
# If not, increase the duplicate count
if (length(dates) != length(unique(dates))){
dup_count <- dup_count + 1
}
}
dup_count/ntests
}
birthday_sim(80)
# Method 3
library(foreach)
library(doParallel)
detectCores() # I have 12 cores in my laptop
numCores <- detectCores() - 2 # Use 10 cores
registerDoParallel(numCores)
# Combine determines how you want your results to be stored, in this case
# we use "c", which stores it as a vector
system.time(bdayp3 <- foreach(n = 1:100, .combine="c") %dopar% birthday_sim(n))
bdayp3
